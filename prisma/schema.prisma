// ── Debt Module ──

model DebtInstrument {
  id                String            @id @default(cuid())
  name              String
  type              DebtType
  bankEntityName    String
  principalAmount   Float
  outstandingBalance Float
  interestRateType  InterestRateType
  interestRateValue Float
  referenceRate     String?
  spread            Float?
  startDate         DateTime
  maturityDate      DateTime
  gracePeriodEndDate DateTime?
  paymentDay        Int?
  paymentFrequency  PaymentFrequency
  creditLimit       Float?
  currentDrawdown   Float?
  contractDocUrl    String?
  status            DebtStatus        @default(ACTIVE)
  notes             String?
  bankAccountId     String?
  bankAccount       OwnBankAccount?   @relation(fields: [bankAccountId], references: [id])
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id])
  covenants         DebtCovenant[]
  schedule          DebtScheduleEntry[]
  transactions      DebtTransaction[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([companyId, status])
}

model DebtScheduleEntry {
  id                String           @id @default(cuid())
  debtInstrumentId  String
  debtInstrument    DebtInstrument   @relation(fields: [debtInstrumentId], references: [id], onDelete: Cascade)
  entryNumber       Int
  dueDate           DateTime
  principalAmount   Float
  interestAmount    Float
  totalAmount       Float
  outstandingAfter  Float
  matched           Boolean          @default(false)
  bankTransactionId String?          @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  matchedAt         DateTime?

  @@index([debtInstrumentId, dueDate])
}

model DebtTransaction {
  id                String           @id @default(cuid())
  debtInstrumentId  String
  debtInstrument    DebtInstrument   @relation(fields: [debtInstrumentId], references: [id], onDelete: Cascade)
  type              DebtTransactionType
  date              DateTime
  amount            Float
  pgcDebitAccount   String
  pgcCreditAccount  String
  bankTransactionId String?          @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  journalEntryId    String?
  journalEntry      JournalEntry?    @relation(fields: [journalEntryId], references: [id])
  notes             String?
  createdAt         DateTime         @default(now())

  @@index([debtInstrumentId])
  @@index([bankTransactionId])
}

model DebtCovenant {
  id                String           @id @default(cuid())
  debtInstrumentId  String
  debtInstrument    DebtInstrument   @relation(fields: [debtInstrumentId], references: [id], onDelete: Cascade)
  name              String
  metric            CovenantMetric
  threshold         Float
  operator          CovenantOperator
  testFrequency     PaymentFrequency
  lastTestedAt      DateTime?
  lastTestedValue   Float?
  isCompliant       Boolean?

  @@index([debtInstrumentId])
}

