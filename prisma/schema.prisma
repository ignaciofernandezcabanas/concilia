generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                     String             @id @default(cuid())
  name                   String
  currency               String             @default("EUR")
  fiscalYearStart        Int                @default(1)
  intercoDebtorAccount   String             @default("5510")
  intercoCreditorAccount String             @default("5520")
  maxCompanies           Int                @default(5)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  autoExecuteThreshold   Float              @default(0.95)
  agentRuns              AgentRun[]
  companies              Company[]
  intercompanyLinks      IntercompanyLink[]
  memberships            Membership[]
}

model Membership {
  id             String           @id @default(cuid())
  role           MembershipRole   @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now())
  invitedBy      String?
  userId         String
  organizationId String
  companyScopes  CompanyScope[]
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model CompanyScope {
  id           String      @id @default(cuid())
  role         CompanyRole @default(VIEWER)
  membershipId String
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  membership   Membership  @relation(fields: [membershipId], references: [id])

  @@unique([membershipId, companyId])
}

model Company {
  id                       String              @id @default(cuid())
  name                     String
  cif                      String
  currency                 String              @default("EUR")
  fiscalYearStartMonth     Int                 @default(1)
  numberFormat             String              @default("eu")
  csvSeparator             String              @default(";")
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  autoApproveThreshold     Float               @default(0.95)
  materialityThreshold     Float               @default(500)
  materialityMinor         Float               @default(5)
  preAlertDays             Int                 @default(7)
  organizationId           String?
  shortName                String?
  type                     CompanyType         @default(STANDALONE)
  acquisitionDate          DateTime?
  consolidationMethod      ConsolidationMethod @default(FULL)
  deactivationDate         DateTime?
  deactivationReason       String?
  firstConsolidationPeriod String?
  fiscalYearEndMonth       Int                 @default(12)
  functionalCurrency       String              @default("EUR")
  geographicRegion         String?
  isActive                 Boolean             @default(true)
  isHoldingCompany         Boolean             @default(false)
  legalName                String?
  localGaap                String              @default("PGC_PYMES")
  nciMethod                NciMethod?
  ownershipPercentage      Float?              @default(100)
  parentCompanyId          String?
  presentationCurrency     String?
  registrationNumber       String?
  segment                  String?
  taxJurisdiction          String              @default("ES")
  needsBusinessProfile     Boolean             @default(true)
  businessProfile          BusinessProfile?
  gestoriaConfig           GestoriaConfig?
  accounts                 Account[]
  accountingPeriods        AccountingPeriod[]
  archiveLogs              ArchiveLog[]
  bankTransactions         BankTransaction[]
  budgets                  Budget[]
  categoryThresholds       CategoryThreshold[]
  organization             Organization?       @relation(fields: [organizationId], references: [id])
  parentCompany            Company?            @relation("SubsidiaryOf", fields: [parentCompanyId], references: [id])
  subsidiaries             Company[]           @relation("SubsidiaryOf")
  companyScopes            CompanyScope[]
  contacts                 Contact[]
  fixedAssets              FixedAsset[]
  inquiries                Inquiry[]
  integrations             Integration[]
  investments              Investment[]
  recurringAccruals        RecurringAccrual[]
  badDebtTrackers          BadDebtTracker[]
  exchangeRateDifferences  ExchangeRateDifference[]
  debtInstruments          DebtInstrument[]
  deferredEntries          DeferredEntry[]
  invoices                 Invoice[]
  journalEntries           JournalEntry[]
  matchingRules            MatchingRule[]
  notifications            Notification[]
  ownBankAccounts          OwnBankAccount[]
  reconciliations          Reconciliation[]
  supportingDocuments      SupportingDocument[]
  syncLogs                 SyncLog[]
  users                    User[]
}

model AccountingPeriod {
  id         String       @id @default(cuid())
  year       Int
  month      Int
  status     PeriodStatus @default(OPEN)
  closedAt   DateTime?
  closedById String?
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  companyId  String
  company    Company      @relation(fields: [companyId], references: [id])

  @@unique([companyId, year, month])
  @@index([companyId, status])
}

model Budget {
  id        String       @id @default(cuid())
  year      Int
  name      String       @default("Presupuesto anual")
  status    BudgetStatus @default(DRAFT)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  companyId String
  company   Company      @relation(fields: [companyId], references: [id])
  lines     BudgetLine[]

  @@unique([companyId, year, name])
}

model BudgetLine {
  id          String @id @default(cuid())
  accountCode String
  month       Int
  amount      Float
  budgetId    String
  budget      Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, accountCode, month])
  @@index([budgetId])
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String?
  role            Role           @default(EDITOR)
  status          UserStatus     @default(PENDING)
  lastLoginAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  companyId       String
  activeCompanyId String?
  activeOrgId     String?
  auditLogs       AuditLog[]
  memberships     Membership[]
  notifications   Notification[]
  company         Company        @relation(fields: [companyId], references: [id])

  @@unique([email, companyId])
}

model IntercompanyLink {
  id             String        @id @default(cuid())
  amount         Float
  date           DateTime
  concept        String?
  status         IntercoStatus @default(DETECTED)
  matchedAt      DateTime?
  companyAId     String
  companyBId     String
  transactionAId String?
  transactionBId String?
  invoiceAId     String?
  invoiceBId     String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status])
}

model Account {
  id                 String                          @id @default(cuid())
  code               String
  name               String
  parentCode         String?
  group              Int
  pygLine            String?
  cashflowType       CashflowType?
  isActive           Boolean                         @default(true)
  companyId          String
  company            Company                         @relation(fields: [companyId], references: [id])
  classifications    BankTransactionClassification[]
  accumDepAssets     FixedAsset[]                    @relation("AccumDepAccount")
  fixedAssets        FixedAsset[]                    @relation("AssetAccount")
  depreciationAssets FixedAsset[]                    @relation("DepreciationAccount")
  invoiceLines       InvoiceLine[]
  journalEntryLines  JournalEntryLine[]

  @@unique([code, companyId])
}

model JournalEntry {
  id           String             @id @default(cuid())
  number       Int
  date         DateTime
  description  String
  type         JournalEntryType   @default(MANUAL)
  status       JournalEntryStatus @default(DRAFT)
  reference    String?
  sourceType   String?
  sourceId     String?
  postedAt     DateTime?
  postedById   String?
  reversalOfId String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  companyId    String
  createdById  String?
  company      Company            @relation(fields: [companyId], references: [id])
  lines                  JournalEntryLine[]
  investmentTransactions InvestmentTransaction[]
  debtTransactions       DebtTransaction[]
  recurringAccrual       RecurringAccrual?      @relation("AccrualEntries", fields: [recurringAccrualId], references: [id])
  recurringAccrualId     String?
  supportingDocument     SupportingDocument?    @relation("SupportingDocEntry")

  @@unique([companyId, number])
  @@index([companyId, date])
  @@index([companyId, status])
}

model JournalEntryLine {
  id             String       @id @default(cuid())
  debit          Float        @default(0)
  credit         Float        @default(0)
  description    String?
  journalEntryId String
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
}

model FixedAsset {
  id                      String             @id @default(cuid())
  name                    String
  description             String?
  serialNumber            String?
  acquisitionDate         DateTime
  acquisitionCost         Float
  residualValue           Float              @default(0)
  usefulLifeMonths        Int
  depreciationMethod      DepreciationMethod @default(LINEAR)
  status                  AssetStatus        @default(ACTIVE)
  accumulatedDepreciation Float              @default(0)
  netBookValue            Float              @default(0)
  monthlyDepreciation     Float              @default(0)
  lastDepreciationDate    DateTime?
  disposalDate            DateTime?
  disposalAmount          Float?
  disposalGainLoss        Float?
  assetAccountId          String
  depreciationAccountId   String
  accumDepAccountId       String
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  companyId               String
  accumDepAccount         Account            @relation("AccumDepAccount", fields: [accumDepAccountId], references: [id])
  assetAccount            Account            @relation("AssetAccount", fields: [assetAccountId], references: [id])
  company                 Company            @relation(fields: [companyId], references: [id])
  depreciationAccount     Account            @relation("DepreciationAccount", fields: [depreciationAccountId], references: [id])

  @@index([companyId, status])
}

model RecurringAccrual {
  id                String           @id @default(cuid())
  description       String
  contactId         String?
  contact           Contact?         @relation(fields: [contactId], references: [id])

  totalAnnualAmount Float
  monthlyAmount     Float

  expenseAccountCode String
  accrualAccountCode String

  frequency         AccrualFrequency @default(MONTHLY)
  startDate         DateTime
  endDate           DateTime?

  linkedInvoiceId   String?
  linkedInvoice     Invoice?         @relation("AccrualInvoice", fields: [linkedInvoiceId], references: [id])
  autoReverse       Boolean          @default(true)

  status            AccrualStatus    @default(ACTIVE)
  lastAccruedDate   DateTime?
  totalAccrued      Float            @default(0)

  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])

  journalEntries    JournalEntry[]   @relation("AccrualEntries")

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId, status])
}

enum AccrualFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum AccrualStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model DeferredEntry {
  id                  String         @id @default(cuid())
  type                DeferredType
  contactId           String
  contact             Contact        @relation("DeferredContact", fields: [contactId], references: [id])
  amount              Float
  description         String?
  date                DateTime

  deferredAccountCode String

  bankTransactionId   String?
  linkedInvoiceId     String?
  linkedInvoice       Invoice?       @relation("DeferredInvoice", fields: [linkedInvoiceId], references: [id])

  status              DeferredStatus @default(PENDING)
  consumedAmount      Float          @default(0)
  remainingAmount     Float

  journalEntryId      String?
  reversalEntryId     String?

  companyId           String
  company             Company        @relation(fields: [companyId], references: [id])
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([companyId, status])
  @@index([contactId, status])
}

enum DeferredType {
  ADVANCE_RECEIVED
  ADVANCE_PAID
}

enum DeferredStatus {
  PENDING
  PARTIALLY_APPLIED
  FULLY_APPLIED
  CANCELLED
}

model BadDebtTracker {
  id                String        @id @default(cuid())
  invoiceId         String        @unique
  invoice           Invoice       @relation(fields: [invoiceId], references: [id])

  overdueDate       DateTime
  overdueMonths     Int

  claimType         ClaimType?
  claimDate         DateTime?
  claimReference    String?

  provisionAmount   Float
  isTaxDeductible   Boolean       @default(false)
  taxDeductibleDate DateTime?

  provisionEntryId  String?
  reversalEntryId   String?

  status            BadDebtStatus @default(MONITORING)

  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([companyId, status])
}

model ExchangeRateDifference {
  id                String          @id @default(cuid())
  reconciliationId  String?
  reconciliation    Reconciliation? @relation(fields: [reconciliationId], references: [id])
  originalCurrency  String
  originalAmount    Float
  bookRate          Float
  settlementRate    Float
  differenceEur     Float
  differenceType    FxDifferenceType
  journalEntryId    String?
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  createdAt         DateTime        @default(now())
  @@index([companyId])
}

enum FxDifferenceType {
  GAIN
  LOSS
}

enum ClaimType {
  BUROFAX
  JUDICIAL
  NOTARIAL
  DEBTOR_INSOLVENCY
}

enum BadDebtStatus {
  MONITORING
  PROVISION_ACCOUNTING
  PROVISION_TAX
  RECOVERED
  WRITTEN_OFF
}

model Investment {
  id                String                @id @default(cuid())
  name              String
  type              InvestmentType
  pgcAccount        String
  isinCif           String?
  investeeCompanyId String?
  acquisitionDate   DateTime
  acquisitionCost   Float
  sharesUnits       Float?
  ownershipPct      Float?
  valuationMethod   ValuationMethod       @default(COST)
  currentValue      Float?
  lastValuationDate DateTime?
  supportingDocUrls String[]
  status            InvestmentStatus      @default(ACTIVE)
  notes             String?
  companyId         String
  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions      InvestmentTransaction[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([companyId])
  @@index([status])
}

model InvestmentTransaction {
  id                String           @id @default(cuid())
  type              InvTxType
  date              DateTime
  amount            Float
  pgcDebitAccount   String
  pgcCreditAccount  String
  notes             String?
  investmentId      String
  investment        Investment       @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  bankTransactionId String?          @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  journalEntryId    String?
  journalEntry      JournalEntry?    @relation(fields: [journalEntryId], references: [id])
  createdAt         DateTime         @default(now())

  @@index([investmentId])
  @@index([bankTransactionId])
}

model OwnBankAccount {
  id              String           @id @default(cuid())
  iban            String
  bankName        String?
  alias           String?
  isActive        Boolean          @default(true)
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  debtInstruments DebtInstrument[]

  @@unique([iban, companyId])
}

model Contact {
  id                String      @id @default(cuid())
  holdedId          String?
  name              String
  cif               String?
  iban              String?
  type              ContactType
  avgPaymentDays    Float?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  companyId         String
  accountingContact String?
  accountingEmail   String?
  email             String?
  paymentTermsDays  Int?
  preferredLanguage String?     @default("es")
  typicalAmountAvg        Float?
  irpfApplicable          Boolean?
  irpfRateImplied         Float?
  latePaymentRisk         String?
  enrichedAt              DateTime?
  enrichmentConfidence    String?
  company           Company     @relation(fields: [companyId], references: [id])
  deferredEntries   DeferredEntry[]  @relation("DeferredContact")
  inquiries         Inquiry[]
  invoices          Invoice[]
  recurringAccruals    RecurringAccrual[]
  supportingDocuments  SupportingDocument[] @relation("SupportingDocContact")

  @@unique([holdedId, companyId])
}

model Invoice {
  id                String           @id @default(cuid())
  holdedId          String?
  number            String
  type              InvoiceType
  issueDate         DateTime
  dueDate           DateTime?
  totalAmount       Float
  netAmount         Float?
  vatAmount         Float?
  currency          String           @default("EUR")
  originalCurrency    String?   @default("EUR")
  originalAmount      Float?
  exchangeRate        Float?
  description       String?
  status            InvoiceStatus    @default(PENDING)
  amountPaid        Float            @default(0)
  amountPending     Float?
  provisionedAmount Float            @default(0)
  provisionType     ProvisionType?
  pdfUrl            String?
  driveFileId       String?
  creditNoteForId   String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  syncedAt          DateTime?
  companyId         String
  contactId         String?
  badDebtTracker    BadDebtTracker?
  inquiries         Inquiry[]
  deferredEntries   DeferredEntry[]  @relation("DeferredInvoice")
  linkedAccruals    RecurringAccrual[] @relation("AccrualInvoice")
  company           Company          @relation(fields: [companyId], references: [id])
  contact           Contact?         @relation(fields: [contactId], references: [id])
  creditNoteFor     Invoice?         @relation("CreditNotes", fields: [creditNoteForId], references: [id])
  creditNotes       Invoice[]        @relation("CreditNotes")
  lines             InvoiceLine[]
  payments          Payment[]
  reconciliations   Reconciliation[]

  @@unique([holdedId, companyId])
  @@index([companyId, status])
  @@index([companyId, type, issueDate])
  @@index([companyId, dueDate])
}

model InvoiceLine {
  id          String   @id @default(cuid())
  description String?
  quantity    Float    @default(1)
  unitPrice   Float
  totalAmount Float
  vatRate     Float?
  invoiceId   String
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id])
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(cuid())
  holdedId  String?  @unique
  amount    Float
  date      DateTime
  method    String?
  invoiceId String
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
}

model BankTransaction {
  id               String                         @id @default(cuid())
  externalId       String?
  valueDate        DateTime
  bookingDate      DateTime?
  amount           Float
  currency         String                         @default("EUR")
  concept          String?
  conceptParsed    String?
  counterpartIban  String?
  counterpartName  String?
  reference        String?
  balanceAfter     Float?
  originalCurrency String?                        @default("EUR")
  originalAmount   Float?
  exchangeRate     Float?
  status           BankTransactionStatus          @default(PENDING)
  priority         TransactionPriority            @default(ROUTINE)
  detectedType     DetectedType?
  classificationId String?
  note             String?
  noteAuthorId     String?
  noteCreatedAt    DateTime?
  reminderDate     DateTime?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  syncedAt         DateTime?
  companyId        String
  duplicateGroupId String?
  classification   BankTransactionClassification? @relation(fields: [classificationId], references: [id])
  company          Company                        @relation(fields: [companyId], references: [id])
  duplicateGroup   DuplicateGroup?                @relation(fields: [duplicateGroupId], references: [id])
  inquiries              Inquiry[]
  reconciliations        Reconciliation[]
  investmentTransactions InvestmentTransaction[]
  debtTransactions       DebtTransaction[]
  debtScheduleEntry      DebtScheduleEntry?

  // Investment/CAPEX classification
  economicCategory    EconomicCategory?
  classificationNotes Json?

  @@unique([externalId, companyId])
  @@index([companyId, status])
  @@index([companyId, valueDate])
  @@index([companyId, counterpartIban])
}

model BankTransactionClassification {
  id           String            @id @default(cuid())
  accountId    String
  cashflowType CashflowType
  description  String?
  transactions BankTransaction[]
  account      Account           @relation(fields: [accountId], references: [id])
}

model DuplicateGroup {
  id           String            @id @default(cuid())
  status       DuplicateStatus   @default(PENDING)
  resolvedAt   DateTime?
  resolution   String?
  transactions BankTransaction[]
}

model Reconciliation {
  id                  String               @id @default(cuid())
  type                ReconciliationType
  confidenceScore     Float?
  matchReason         String?
  status              ReconciliationStatus @default(PROPOSED)
  invoiceAmount       Float?
  bankAmount          Float?
  difference          Float?
  differenceReason    DifferenceReason?
  differenceAccountId String?
  resolvedAt          DateTime?
  resolvedById        String?
  resolution          String?
  bankTransactionId   String?
  invoiceId           String?
  companyId           String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  inquiries                 Inquiry[]
  exchangeRateDifference    ExchangeRateDifference[]
  bankTransaction           BankTransaction?     @relation(fields: [bankTransactionId], references: [id])
  company                   Company              @relation(fields: [companyId], references: [id])
  invoice                   Invoice?             @relation(fields: [invoiceId], references: [id])
  supportingDocumentId      String?
  supportingDocument        SupportingDocument?  @relation(fields: [supportingDocumentId], references: [id])

  // Match con diferencia
  differenceType                DifferenceType?
  differenceAmount              Float?
  differenceJournalEntryId      String?

  // Aclaración por email
  clarificationEmailSentAt      DateTime?
  clarificationEmailMessageId   String?
  clarificationEmailTo          String?
  clarificationEmailSubject     String?
  clarificationReceivedAt       DateTime?
  clarificationSummary          String?
  clarificationDifferenceType   DifferenceType?

  @@index([companyId, status])
  @@index([bankTransactionId])
  @@index([invoiceId])
  @@index([clarificationEmailMessageId])
}

model MatchingRule {
  id                   String        @id @default(cuid())
  type                 RuleType
  isActive             Boolean       @default(true)
  timesApplied         Int           @default(0)
  pattern              String?
  counterpartIban      String?
  contactId            String?
  minAmount            Float?
  maxAmount            Float?
  action               String
  accountCode          String?
  cashflowType         CashflowType?
  companyId            String
  createdAt            DateTime      @default(now())
  createdById          String?
  conceptContains      String?
  counterpartName      String?
  differencePercentMax Float?
  differencePercentMin Float?
  differenceReason     String?
  lastExecutedAt       DateTime?
  name                 String?
  origin               RuleOrigin    @default(MANUAL)
  priority             Int           @default(0)
  status               RuleStatus    @default(ACTIVE)
  transactionDirection String?
  company              Company       @relation(fields: [companyId], references: [id])

  @@index([companyId, status, priority])
  @@index([companyId, isActive])
}

model Integration {
  id            String            @id @default(cuid())
  type          IntegrationType
  status        IntegrationStatus @default(DISCONNECTED)
  config        Json?
  lastSyncAt    DateTime?
  syncFrequency String            @default("daily")
  error         String?
  companyId     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  company       Company           @relation(fields: [companyId], references: [id])

  @@unique([type, companyId])
}

model SyncLog {
  id               String    @id @default(cuid())
  source           String
  action           String
  status           String
  recordsProcessed Int       @default(0)
  recordsCreated   Int       @default(0)
  recordsUpdated   Int       @default(0)
  errors           Json?
  duration         Int?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id])

  @@index([companyId, startedAt])
}

model ArchiveLog {
  id            String    @id @default(cuid())
  quarter       String
  status        String
  issuedCount   Int       @default(0)
  receivedCount Int       @default(0)
  errorCount    Int       @default(0)
  errors        Json?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  actionUrl String?
  metadata  Json?
  userId    String
  companyId String
  createdAt DateTime         @default(now())
  company   Company          @relation(fields: [companyId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([companyId, createdAt])
}

model AgentRun {
  id                 String         @id @default(cuid())
  status             AgentRunStatus @default(RUNNING)
  startedAt          DateTime       @default(now())
  completedAt        DateTime?
  companiesProcessed Int            @default(0)
  txsProcessed       Int            @default(0)
  txsAutoExecuted    Int            @default(0)
  txsToBandeja       Int            @default(0)
  llmCallsTotal      Int            @default(0)
  llmCostEstimate    Float          @default(0)
  errorsCount        Int            @default(0)
  companyResults     Json?
  aiCallLog          Json?
  briefing           String?
  organizationId     String
  organization       Organization   @relation(fields: [organizationId], references: [id])

  @@index([organizationId, startedAt])
}

model ConfidenceAdjustment {
  id          String    @id @default(cuid())
  category    String
